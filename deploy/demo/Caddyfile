{
	email {$ACME_EMAIL}
}

# Public marketing landing → agendamiento.nexosoftdev.com
# TLS via HTTP challenge (single host, no wildcard needed here).
{$LANDING_DOMAIN} {
	# The lead form posts to /rest/* on the backend.
	@api path /rest/*
	reverse_proxy @api backend:8000

	reverse_proxy marketing:3000
}

# Wildcard demo domain. A single site block handles every clinic subdomain to
# avoid ambiguity between overlapping wildcards. Routing inside:
#   - admin-<clinic>.demo-...  → Nuxt admin panel
#   - <clinic>.demo-...        → Nuxt patient booking site
#   - /rest, /dadmin, /static, /media → Django backend (any host)
# TLS for the wildcard is issued via DigitalOcean DNS-01.
*.{$DEMO_DOMAIN}, {$DEMO_DOMAIN} {
	tls {
		dns digitalocean {$DO_AUTH_TOKEN}
	}

	# Django API / admin / assets first, regardless of host.
	@backend path /rest/* /dadmin/* /static/* /media/*
	reverse_proxy @backend backend:8000

	# Admin panel hosts: admin-<clinic>.demo-agendamiento.nexosoftdev.com
	# (host matcher with * only matches a whole label, so use a regexp to match
	# the "admin-" prefix within the first label).
	@adminhost header_regexp Host ^admin-
	reverse_proxy @adminhost admin:3000

	# Everything else is the Nuxt patient booking app (SSR).
	reverse_proxy frontend:3000
}
