# Admin panel (apps/admin) — served under /panel on each demo clinic subdomain.
# Build context is the frontend workspace root:
#   docker build -f ../deploy/demo/Dockerfile.admin agendamiento-saas-frontend
FROM node:22-slim AS build

ENV PNPM_HOME=/pnpm \
    PATH=/pnpm:$PATH
RUN corepack enable

WORKDIR /app

# Public config baked into the SSR bundle.
ARG NUXT_PUBLIC_API_BASE
ARG NUXT_PUBLIC_PLATFORM_DOMAIN
ARG NUXT_APP_BASE_URL
ENV NUXT_PUBLIC_API_BASE=$NUXT_PUBLIC_API_BASE \
    NUXT_PUBLIC_PLATFORM_DOMAIN=$NUXT_PUBLIC_PLATFORM_DOMAIN \
    NUXT_APP_BASE_URL=$NUXT_APP_BASE_URL

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY apps/admin/package.json apps/admin/package.json
COPY packages/shared/package.json packages/shared/package.json
RUN pnpm install --frozen-lockfile

COPY . .
WORKDIR /app/apps/admin
# Give Node enough heap for the Nitro bundle (needs swap on a 2GB droplet).
ENV NODE_OPTIONS=--max-old-space-size=2560
# nuxt prepare writes .nuxt in the app dir, but the build's esbuild resolves
# tsconfig.app.json from the workspace root — copy it there.
RUN pnpm exec nuxt prepare \
    && cp -r .nuxt /app/.nuxt \
    && pnpm exec nuxt build
WORKDIR /app

# ── Runtime ─────────────────────────────────────────────────────────────────
FROM node:22-slim AS runtime
ENV NODE_ENV=production \
    NITRO_HOST=0.0.0.0 \
    NITRO_PORT=3000
WORKDIR /app
COPY --from=build /app/apps/admin/.output ./.output
EXPOSE 3000
CMD ["node", ".output/server/index.mjs"]
