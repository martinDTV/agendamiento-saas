# Copy to deploy/demo/.env and fill in. NEVER commit the real .env.
# This file documents every variable the demo stack needs.

# Demo wildcard domain (no protocol). All <clinic>.<this> resolve to the stack.
DEMO_DOMAIN=demo-agendamiento.nexosoftdev.com

# Days a demo clinic lives before purge_demo_tenants deletes it.
DEMO_TENANT_TTL_DAYS=7

# Django
SECRET_KEY=change-me-to-a-long-random-string

# Postgres (the ISOLATED demo database — never the production one)
POSTGRES_DB=agendamiento_demo
POSTGRES_USER=demo
POSTGRES_PASSWORD=change-me

# TLS / ACME
ACME_EMAIL=hola@nexosoftdev.com

# name.com API credentials (for wildcard TLS DNS-01 challenge)
# Generate at https://www.name.com/account/settings/api
NAMECOM_USER=your-namecom-username
NAMECOM_TOKEN=your-namecom-api-token
