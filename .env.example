# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=cambiar-por-clave-segura-en-produccion
SECRET_KEY_LOCAL=cambiar-por-clave-jwt
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.miapp.com

# ── Database (PostgreSQL via URL) ─────────────────────────────────────────────
# Formato: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://martin:1234@localhost:5432/agendamiento-saas

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/1

# ── Celery ─────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_LIFETIME_DAYS=30
JWT_REFRESH_LIFETIME_DAYS=30

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOW_ALL_ORIGINS=True
# Si CORS_ALLOW_ALL_ORIGINS=False, especificar origins separados por coma:
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ── Tenancy ───────────────────────────────────────────────────────────────────
PLATFORM_DOMAIN=miapp.com

# ── OIDC / Keycloak (opcional) ────────────────────────────────────────────────
OIDC_RP_CLIENT_ID=tu-client-id
OIDC_RP_CLIENT_SECRET=tu-client-secret
OIDC_OP_AUTHORIZATION_ENDPOINT=http://localhost:8080/realms/tu-realm/protocol/openid-connect/auth
OIDC_OP_TOKEN_ENDPOINT=http://localhost:8080/realms/tu-realm/protocol/openid-connect/token
OIDC_OP_USER_ENDPOINT=http://localhost:8080/realms/tu-realm/protocol/openid-connect/userinfo
OIDC_OP_JWKS_ENDPOINT=http://localhost:8080/realms/tu-realm/protocol/openid-connect/certs
OIDC_RP_SIGN_ALGO=RS256

# ── Rate Limiting ─────────────────────────────────────────────────────────────
THROTTLE_ANON=100/hour
THROTTLE_USER=1000/hour
THROTTLE_BOOKING_CREATE=5/hour
THROTTLE_SLOTS=60/hour

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_ENABLED=False
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── AI / Ollama ───────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_TEXT=gemma2:9b
OLLAMA_MODEL_EMBED=nomic-embed-text:latest
OLLAMA_TIMEOUT=10

# ── Storage S3-compatible (Cloudflare R2) ─────────────────────────────────────
# AWS_ACCESS_KEY_ID=tu-r2-access-key
# AWS_SECRET_ACCESS_KEY=tu-r2-secret-key
# AWS_STORAGE_BUCKET_NAME=tu-bucket
# AWS_S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# AWS_S3_CUSTOM_DOMAIN=assets.miapp.com

# ── Email ─────────────────────────────────────────────────────────────────────
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=465
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=tu-resend-api-key
# EMAIL_USE_SSL=True
# DEFAULT_FROM_EMAIL=no-reply@miapp.com

# ── WhatsApp / Twilio ─────────────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=tu-auth-token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── PayPal Subscriptions ──────────────────────────────────────────────────────
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_WEBHOOK_ID=
# URLs donde PayPal redirige al usuario después de aprobar/cancelar.
# En prod usa el dominio del admin, e.g. https://admin.tenant.miapp.com/ajustes
PAYPAL_RETURN_URL=http://localhost:3002/ajustes
PAYPAL_CANCEL_URL=http://localhost:3002/ajustes
